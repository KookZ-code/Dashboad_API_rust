# backend/.env.example
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า
# ห้าม commit .env เด็ดขาด

# ─── SQLite (items CRUD) ───────────────────────────────────────────────────────
DATABASE_URL=sqlite://./dev.db

# ─── SQLite (WB-UPH module) ────────────────────────────────────────────────────
# Path to central.db (hourly bond-unit scan records). Network share or local file.
# ⚠️ ถ้า path มีช่องว่าง (เช่น share "wire bond") ต้องครอบด้วย single quote:
#    CENTRAL_DB_PATH='\\mth-sv-file\wire bond\UPH mornitor\central.db'
# local: CENTRAL_DB_PATH=./central.db   |   D:/path/to/central.db
CENTRAL_DB_PATH=./central.db

# ─── PostgreSQL (DA-UPH module) ────────────────────────────────────────────────
# Die Attach scan output (db `uph`, written by UPHServer.exe). ว่าง = ปิด DA-UPH
# (endpoints /api/v1/da-uph/* คืน 503). ไม่ครอบ scheme ด้วย quote.
# DA_DB_URL=postgres://uph_app:uphpass@MTH-DK-B12416:5432/uph
DA_DB_URL=

# ─── MSSQL (dashboard API) ────────────────────────────────────────────────────
DB_SERVER=mth-cl-mthsql
DB_PORT=1433
DB_NAME=MTHAI_ppm_db1
DB_USER=MTHAI_ppm
DB_PASSWORD=

# ─── Dashboard API ────────────────────────────────────────────────────────────
# API Key สำหรับ x-api-key header (ถ้าว่าง = ปิด auth)
API_KEY=mch_dev_12345
# ชื่อ view และ table — ปรับตาม DB
VIEW_NAME=vw_job_nokey
MACHINE_TABLE=dbo.machine

# ─── Oracle (ISO/FS area job/downtime data) ────────────────────────────────────
# ORA_ENABLED=0 → ปิด (ISO/FS เสิร์ฟจาก MSSQL อย่างเดียว)
# ⚠️ ORA_CLIENT_LIB (มี backslash) ต้องครอบ single quote · ตอนรันต้องมี client bin บน PATH
# ⚠️ ตอน build ต้องมี gcc (MSYS2 C:\msys64\ucrt64\bin) บน PATH — oracle crate compile ODPI-C
ORA_ENABLED=0
ORA_USER=
ORA_PASSWORD=
ORA_DSN=host:1521/SERVICE
ORA_CLIENT_LIB='C:\OracleX64\product\11.2.0\client_1\bin'
ORA_VIEW=Vw_Asodowntime_2025on
ORA_LIVE_VIEW=EQ_USER.V_EQDOWNTIME

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development

# CORS — origin ของ frontend
FRONTEND_ORIGIN=http://localhost:5173

# Logging level: error | warn | info | debug | trace
RUST_LOG=info
